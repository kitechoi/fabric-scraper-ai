# 둘 중 하나만 설정하면 됨 (config.py에서 LLM_PROVIDER로 선택)
OPENAI_API_KEY=
GEMINI_API_KEY=

# 사용할 LLM 제공자: "openai" 또는 "gemini"
LLM_PROVIDER=

# Notion 연동 (선택 — 없으면 Notion 저장 건너뜀)
# API 키: https://www.notion.so/my-integrations 에서 발급
NOTION_API_KEY=
# 데이터베이스 ID: Notion DB 페이지 URL에서 추출 (32자리 hex)
NOTION_DATABASE_ID=
